# =============================================================
# MiroFish-Offline Configuration
# =============================================================
# This fork runs entirely on local models — no cloud APIs needed.
# Copy this file to .env and adjust values for your setup.
# =============================================================

# ===== LLM Configuration (OpenAI-compatible format) =====
# Points to local Ollama server. Any non-empty value for API key works.
# For Docker: use service name "ollama" instead of "localhost"
LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL_NAME=qwen2.5:32b
# Force Ollama-specific request options (e.g. num_ctx). Use openai / lm_studio for other OpenAI-compatible servers.
# LLM_PROVIDER=ollama
# Lighter model for development (less VRAM):
# LLM_MODEL_NAME=qwen2.5:14b
# Per-request HTTP timeout in seconds (ontology / big prompts on LM Studio often need 1800+)
# LLM_HTTP_TIMEOUT_SEC=1800
# Optional: NER extraction max output tokens (completion API)
# NER_MAX_OUTPUT_TOKENS=8192
#
# --- Graph ingest / context (Phase 8 runbook) ---
# Chunk size for file→graph builds (must fit in LLM context with ontology + prompts).
# GRAPH_CHUNK_SIZE=500
# GRAPH_CHUNK_OVERLAP=50
# Target ~6–10% overlap vs chunk size (e.g. 500 → 30–50).
#
# Ollama: context window for prompts (must be ≥ ontology + system prompt + chunk).
# OLLAMA_NUM_CTX=8192
# LM Studio: set context in the server UI to match or exceed the same budget.
#
# Provider hint: force Ollama extra_body (num_ctx) when not using port 11434
# LLM_PROVIDER=ollama

# --- Phase 9: optional NER/RE-only LLM (stronger extract model / second server) ---
# If unset, NER uses LLM_BASE_URL + LLM_MODEL_NAME + LLM_API_KEY.
# LLM_EXTRACT_BASE_URL=http://localhost:1234/v1
# LLM_EXTRACT_MODEL_NAME=qwen2.5:14b
# LLM_EXTRACT_API_KEY=ollama
# LLM_EXTRACT_HTTP_TIMEOUT_SEC=1800
# Optional: different context only for the extract client (Ollama)
# OLLAMA_EXTRACT_NUM_CTX=16384

# --- Phase 10: extraction pipeline ---
# Two-pass NER (entities, then relations) — better JSON completeness for long relation lists
# NER_TWO_PASS=true
# Top-K existing graph entities to inject as linking hints (0 = disable)
# NER_LINK_TOP_K=12
# Chunk preset when GRAPH_CHUNK_SIZE is unset: small | medium | large
# GRAPH_CHUNK_PROFILE=medium
# Prefer paragraph boundaries when chunking files (see file_parser.split_text_into_chunks)
# GRAPH_CHUNK_PREFER_PARAGRAPH=true

# --- Phase 11: merge graph / dedupe ---
# JSON file: surface form -> canonical entity name (see docs/golden-set/entity-aliases.example.json)
# ENTITY_ALIAS_JSON_PATH=docs/golden-set/entity-aliases.example.json
# Reuse existing entity uuid when embedding similarity is high (same graph_id)
# GRAPH_MERGE_VECTOR_ENABLED=true
# GRAPH_MERGE_VECTOR_THRESHOLD=0.88
# GRAPH_MERGE_VECTOR_AMBIG_LOW=0.72
# LLM adjudication for scores between LOW and THRESHOLD (extra LLM calls)
# GRAPH_MERGE_LLM_ADJUDICATE=false
# Merge duplicate facts: same src/tgt/type + normalized fact -> append episode_ids
# RELATION_DEDUPE_ENABLED=true
# Max entity summary LLM refreshes per chunk (0 = off)
# ENTITY_SUMMARY_MAX_PER_CHUNK=0

# --- Phase 12: temporal memory (RELATION valid_at / invalid_at) ---
# Enable contradiction handling: new same (src,tgt,type) + different fact -> prior active edges get invalid_at
# GRAPH_TEMPORAL_ENABLED=true
# Supersede same triple on ingest (default on when temporal enabled)
# GRAPH_TEMPORAL_SUPERSEDE_SAME_TRIPLE=true
# Retrieval: hide edges with invalid_at set (default on)
# GRAPH_TEMPORAL_QUERY_ACTIVE_ONLY=true
# Optional default as-of for hybrid search + graph_data (ISO-8601, UTC recommended)
# GRAPH_QUERY_AS_OF_ISO=2025-06-01T00:00:00+00:00

# --- Phase 13: hybrid tuning, expansion, rerank, cache ---
# SEARCH_VECTOR_WEIGHT=0.7
# SEARCH_KEYWORD_WEIGHT=0.3
# Neighbor hops after hybrid edge hits (0 = off). Degree cap via EXPAND_EXTRA / MAX_PER_SEED.
# GRAPH_SEARCH_EXPAND_HOPS=0
# GRAPH_SEARCH_EXPAND_EXTRA=24
# GRAPH_SEARCH_EXPAND_MAX_PER_SEED=8
# Optional: only expand along neighbors that have one of these Neo4j labels (comma-separated)
# GRAPH_SEARCH_EXPAND_ENTITY_TYPES=Person,Organization
# Token-overlap rerank on top-M fused hits (0 = off)
# GRAPH_SEARCH_RERANK_TOP_M=0
# GRAPH_SEARCH_RERANK_BOOST=0.15
# Embedding text cache TTL in seconds (0 = no expiry, legacy behavior)
# EMBEDDING_CACHE_TTL_SEC=0
# Full hybrid search result cache TTL (seconds); useful for long simulations
# GRAPH_SEARCH_RESULT_CACHE_TTL_SEC=0

# --- Phase 14: jobs, backpressure, admin metrics ---
# Persist task JSON snapshots for poll-after-restart (directory must be writable)
# GRAPH_JOB_PERSIST_DIR=./uploads/graph_jobs
# Max concurrent add_text / NER LLM calls (0 = unlimited)
# LLM_INGEST_MAX_CONCURRENT=2
# Chunks per progress batch during graph build / jobs/chunks
# GRAPH_INGEST_BATCH_SIZE=3

# ===== Neo4j Configuration =====
# For Docker: use service name "neo4j" instead of "localhost"
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mirofish
# NEO4J_MAX_POOL_SIZE=50
# NEO4J_ACQUISITION_TIMEOUT=60

# ===== Embedding Configuration =====
# Uses Ollama's embedding endpoint
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BASE_URL=http://localhost:11434
# For Docker: EMBEDDING_BASE_URL=http://ollama:11434

# ===== OASIS / CAMEL-AI Configuration =====
# CAMEL-AI reads OPENAI_API_KEY and OPENAI_API_BASE_URL
# Points to same local Ollama server
OPENAI_API_KEY=ollama
OPENAI_API_BASE_URL=http://localhost:11434/v1

# ===== Docker-mode overrides =====
# Uncomment these when running ALL services inside Docker
# (backend container talks to neo4j/ollama containers by service name)
# LLM_BASE_URL=http://ollama:11434/v1
# NEO4J_URI=bolt://neo4j:7687
# EMBEDDING_BASE_URL=http://ollama:11434
# OPENAI_API_BASE_URL=http://ollama:11434/v1

# ===== API rate limiting (production; disabled when FLASK_DEBUG=True) =====
# RATE_LIMIT_RPM=120
